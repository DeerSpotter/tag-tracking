    s &= vbCrLf
    s &= "            Try" & vbCrLf
    s &= "                iLogicVb.Automation.RunExternalRule(p, tempRuleName)" & vbCrLf
    s &= "                count += 1" & vbCrLf
    s &= "            Catch ex As Exception" & vbCrLf
    s &= "                WF.MessageBox.Show(""Failed on tagged part:"" & vbCrLf & p.FullFileName & vbCrLf & vbCrLf & ""Rule path:"" & vbCrLf & tempRulePath & vbCrLf & vbCrLf & ex.Message, ""Internal CAD Tag"")" & vbCrLf
    s &= "            End Try" & vbCrLf
