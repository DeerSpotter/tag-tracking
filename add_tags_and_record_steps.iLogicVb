    s &= "    Catch" & vbCrLf
    s &= "        Try" & vbCrLf
    s &= "            asmDoc.SelectSet.Clear()" & vbCrLf
    s &= "        Catch" & vbCrLf
    s &= "        End Try" & vbCrLf
    s &= "    End Try" & vbCrLf
    s &= vbCrLf
    s &= "    Dim changedCount As Integer = 0" & vbCrLf
