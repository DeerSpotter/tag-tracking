    s &= "Private Function SetFeatureActiveByTag(topAsm As INV.AssemblyDocument, tagNs As String, tagKey As String, wantedTag As String, featureName As String, activeState As Boolean) As Integer" & vbCrLf
    s &= vbCrLf
    s &= "    Dim count As Integer = 0" & vbCrLf
    s &= "    Dim tempRuleName As String = ""__TEMP_TAG_FEATURE_ACTIVE""" & vbCrLf
    s &= "    Dim tempRuleFolder As String = GetFirstExternalRuleDirectory()" & vbCrLf
