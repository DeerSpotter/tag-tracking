    s &= "        End If" & vbCrLf
    s &= vbCrLf
    s &= "    Next" & vbCrLf
    s &= vbCrLf
    s &= "    Try" & vbCrLf
    s &= "        If IO.File.Exists(tempRulePath) Then" & vbCrLf
    s &= "            IO.File.Delete(tempRulePath)" & vbCrLf
    s &= "        End If" & vbCrLf
    s &= "    Catch" & vbCrLf
    s &= "    End Try" & vbCrLf
    s &= vbCrLf
    s &= "    Return count" & vbCrLf
    s &= vbCrLf
    s &= "End Function" & vbCrLf
    s &= vbCrLf

    s &= "Private Function GetFirstExternalRuleDirectory() As String" & vbCrLf
    s &= vbCrLf
    s &= "    Try" & vbCrLf
    s &= "        Dim dirs As Object = iLogicVb.Automation.FileOptions.ExternalRuleDirectories" & vbCrLf
    s &= "        Dim d As String" & vbCrLf
    s &= vbCrLf
    s &= "        For Each d In dirs" & vbCrLf
    s &= "            If Not String.IsNullOrWhiteSpace(d) Then" & vbCrLf
    s &= "                If IO.Directory.Exists(d) Then" & vbCrLf
    s &= "                    Return d" & vbCrLf
    s &= "                End If" & vbCrLf
    s &= "            End If" & vbCrLf
    s &= "        Next" & vbCrLf
    s &= "    Catch" & vbCrLf
    s &= "    End Try" & vbCrLf
    s &= vbCrLf
    s &= "    Return """"" & vbCrLf
    s &= vbCrLf
    s &= "End Function" & vbCrLf

    GetGeneratedHelperCode = s

End Function

Private Sub ShowCodeHelp(tagNs As String, tagKey As String)

    Dim helpLines As String() = {
        "# Internal CAD Tag Action Recorder",
        "",
        "## Purpose",
        "",
        "The Internal CAD Tag Action Recorder is an Autodesk Inventor iLogic tool used to mark parts and assemblies with internal CAD tags, find those tags later, record actions against tagged files, and generate replayable iLogic code.",
        "",
        "The core use case is simple:",
        "",
        "1. Tag a file or selected occurrence document.",
        "2. Record an action such as suppress occurrence, unsuppress occurrence, suppress feature, or unsuppress feature.",
        "3. Generate replayable iLogic code.",
        "4. Run the replay code later against the same assembly structure.",
        "",
        "The tool is intended for repeatable CAD cleanup, configuration, and automation work where selected components or part features must be controlled by a stable internal tag rather than by browser name alone.",
        "",
        "## High level architecture",
        "",
        "The tool has four main layers.",
        "",
        "1. Tag storage layer",
        "2. User action layer",
        "3. Recorder layer",
        "4. Generated replay layer",
        "",
        "The tag storage layer writes and reads Inventor AttributeSets.",
        "",
        "The user action layer provides buttons for writing tags, removing tags, searching tags, recording occurrence actions, recording feature actions, showing generated code, and clearing recorded steps.",
        "",
        "The recorder layer writes compact action records to a temporary text file.",
        "",
        "The generated replay layer converts those compact records into a standalone iLogic rule that can reproduce the recorded actions.",
        "",
        "## Core constants",
        "",
        "The live recorder uses these tag constants.",
        "",
        "```vb",
        "Const TAG_NS As String = """ & tagNs & """",
        "Const TAG_KEY As String = """ & tagKey & """",
        "Const DATE_KEY As String = ""TaggedDate""",
        "Const USER_KEY As String = ""TaggedBy""",
        "Const DOC_TYPE_KEY As String = ""TaggedDocumentType""",
        "```",
        "",
        "`TAG_NS` is the AttributeSet name.",
        "",
        "`TAG_KEY` is the main internal CAD tag value.",
        "",
        "`DATE_KEY` stores when the tag was written.",
        "",
        "`USER_KEY` stores who wrote the tag.",
        "",
        "`DOC_TYPE_KEY` stores whether the tagged file was treated as a part or an assembly.",
        "",
        "## Tag storage model",
        "",
        "The tool writes the same tag to two locations when possible.",
        "",
        "```text",
        "Document object",
        "ComponentDefinition object",
        "```",
        "",
        "For a part, this means:",
        "",
        "```text",
        "PartDocument",
        "PartDocument.ComponentDefinition",
        "```",
        "",
        "For an assembly, this means:",
        "",
        "```text",
        "AssemblyDocument",
        "AssemblyDocument.ComponentDefinition",
        "```",
        "",
        "This dual write is intentional. Some Inventor contexts expose document attributes more reliably, while other contexts expose component definition attributes more reliably.",
        "",
        "When checking for a matching tag, the code should check both locations.",
        "",
        "```vb",
        "HasTagValue(occDoc, TAG_NS, TAG_KEY, wantedTag)",
        "HasComponentDefinitionTagValue(occDoc, TAG_NS, TAG_KEY, wantedTag)",
        "```",
        "",
        "A match is valid if either location contains the requested tag.",
        "",
        "## What a tag represents",
        "",
        "A tag represents the file identity or automation group you want the tool to act on.",
        "",
        "The tag is not the occurrence name.",
        "",
        "The tag is not the file name.",
        "",
        "The tag is not the feature name.",
        "",
        "The tag is a stable internal marker written into the Inventor document attributes.",
        "",
        "Occurrence names can change.",
        "",
        "Browser names can change.",
        "",
        "File paths can move.",
        "",
        "The tag is meant to remain a stable automation target.",
        "",
        "## User interface actions",
        "",
        "### WRITE TAG",
        "",
        "Writes the custom tag to the active part or active assembly.",
        "",
        "When the active document is a part, the tool writes to the part document and part component definition.",
        "",
        "When the active document is an assembly, the tool writes to the assembly document and assembly component definition.",
        "",
        "After writing the tag, the file is saved.",
        "",
        "### REMOVE TAG",
        "",
        "Removes the internal CAD tag.",
        "",
        "The removal form supports two logical scopes.",
        "",
        "```text",
        "SPECIFIC",
        "ALL",
        "```",
        "",
        "`SPECIFIC` removes tags from the current open file only.",
        "",
        "`ALL` removes tags from the current assembly and all referenced parts and assemblies.",
        "",
        "Each file can contain up to two tag locations:",
        "",
        "```text",
        "Document level",
        "Component definition level",
        "```",
        "",
        "The removal count is a tag location count, not a file count.",
        "",
        "### CHECK TAG",
        "",
        "Searches the current assembly for one exact tag name.",
        "",
        "The search checks the top assembly first, then iterates referenced documents.",
        "",
        "The result reports checked assemblies, checked parts, and matching tagged files.",
        "",
        "### SEARCH ALL",
        "",
        "Searches the current assembly for every internal CAD tag.",
        "",
        "This is an audit action.",
        "",
        "It reports all found tags, tagged date, tagged user, and tagged document type when available.",
        "",
        "### CODE HELP",
        "",
        "Shows this internal reference document in a copyable text box.",
        "",
        "The output is Markdown style so it can also be saved as a SKILL.md reference document.",
        "",
        "### SUPPRESS OCC",
        "",
        "Records and runs a tag based occurrence suppression action.",
        "",
        "The user selects one occurrence.",
        "",
        "The tool resolves the effective tag for that selected occurrence.",
        "",
        "If the selected occurrence document already has a tag, that tag is used.",
        "",
        "If the selected occurrence document does not have a tag, the tool asks whether to write the current typed tag to the selected occurrence document.",
        "",
        "After a tag is resolved, the tool finds all matching tagged occurrences and suppresses or excludes them.",
        "",
        "Then it records:",
        "",
        "```text",
        "SUPPRESS_OCC|TagName",
        "```",
        "",
        "### UNSUPPRESS OCC",
        "",
        "Records and runs a tag based occurrence unsuppression action.",
        "",
        "The user can type the tag directly or select one occurrence to read its tag.",
        "",
        "After a tag is resolved, the tool finds all matching tagged occurrences and unsuppresses or includes them.",
        "",
        "Then it records:",
        "",
        "```text",
        "UNSUPPRESS_OCC|TagName",
        "```",
        "",
        "### SUPPRESS FEATURE",
        "",
        "Records and runs a part feature suppression action.",
        "",
        "The user must run this while a part file is active.",
        "",
        "The tool resolves the effective tag for the active file.",
        "",
        "The user selects a feature from the model tree.",
        "",
        "The tool reads the selected feature name and suppresses it.",
        "",
        "Then it records:",
        "",
        "```text",
        "SUPPRESS_FEATURE|TagName|FeatureName",
        "```",
        "",
        "### UNSUPPRESS FEATURE",
        "",
        "Records and runs a part feature unsuppression action.",
        "",
        "The user must run this while a part file is active.",
        "",
        "The tool resolves the effective tag for the active file.",
        "",
        "The user selects a feature from the model tree.",
        "",
        "The tool reads the selected feature name and unsuppresses it.",
        "",
        "Then it records:",
        "",
        "```text",
        "UNSUPPRESS_FEATURE|TagName|FeatureName",
        "```",
        "",
        "### SHOW GENERATED CODE",
        "",
        "Reads the recorder file and builds a standalone iLogic replay rule.",
        "",
        "The generated code appears in a copyable text box.",
        "",
        "### CLEAR STEPS",
        "",
        "Deletes the recorder file.",
        "",
        "Use this when the next generated replay code should contain only new actions.",
        "",
        "## Recorder file",
        "",
        "The recorder file is stored in the Windows temp folder.",
        "",
        "```vb",
        "Dim recorderFile As String = IO.Path.Combine(IO.Path.GetTempPath(), ""InternalCadTag_ActionRecorder.txt"")",
        "```",
        "",
        "Each recorded action is stored as one line.",
        "",
        "Occurrence action format:",
        "",
        "```text",
        "SUPPRESS_OCC|TagName",
        "UNSUPPRESS_OCC|TagName",
        "```",
        "",
        "Feature action format:",
        "",
        "```text",
        "SUPPRESS_FEATURE|TagName|FeatureName",
        "UNSUPPRESS_FEATURE|TagName|FeatureName",
        "```",
        "",
        "When a new recordable action starts and the file already has content, the tool asks whether to clear previous steps.",
        "",
        "Yes means delete the old recorder file and continue.",
        "",
        "No means append the new action to the existing recorder file.",
        "",
        "## Generated replay code",
        "",
        "The generated replay code is built by `BuildGeneratedCode` and `GetGeneratedHelperCode`.",
        "",
        "`BuildGeneratedCode` creates the top level replay rule.",
        "",
        "`GetGeneratedHelperCode` appends all helper functions needed by the replay rule.",
        "",
        "The generated replay code includes this startup pattern.",
        "",
        "```vb",
        "AddReference ""System.Windows.Forms.dll""",
        "Imports INV = Inventor",
        "Imports WF = System.Windows.Forms",
        "Imports IO = System.IO",
        "",
        "Sub Main()",
        "    Const TAG_NS As String = ""INTERNAL_CAD_TAG""",
        "    Const TAG_KEY As String = ""TagName""",
        "",
        "    Dim app As INV.Application = ThisApplication",
        "    Dim activeDoc As INV.Document = app.ActiveDocument",
        "    Dim asm As INV.AssemblyDocument = TryCast(activeDoc, INV.AssemblyDocument)",
        "    Dim part As INV.PartDocument = TryCast(activeDoc, INV.PartDocument)",
        "    Dim txn As INV.Transaction = Nothing",
        "```",
        "",
        "The generated replay code starts an Inventor transaction.",
        "",
        "```vb",
        "txn = app.TransactionManager.StartTransaction(activeDoc, ""Internal CAD Tag Replay"")",
        "```",
        "",
        "If the replay succeeds, the transaction is ended.",
        "",
        "If an exception occurs, the transaction is aborted.",
        "",
        "This gives the generated replay rule a cleaner undo behavior.",
        "",
        "## Generated replay occurrence pipeline",
        "",
        "Occurrence replay actions use this pipeline.",
        "",
        "```text",
        "Recorded tag",
        "Search assembly occurrence tree",
        "Collect all matching occurrences",
        "Apply desired active state",
        "Verify result",
        "Save once",
        "```",
        "",
        "The generated suppress call should be:",
        "",
        "```vb",
        "SuppressOccurrencesByTag(asm.ComponentDefinition.Occurrences, TAG_NS, TAG_KEY, ""TagName"")",
        "```",
        "",
        "The generated unsuppress call should be:",
        "",
        "```vb",
        "UnsuppressOccurrencesByTagSafe(asm.ComponentDefinition.Occurrences, TAG_NS, TAG_KEY, ""TagName"")",
        "```",
        "",
        "Both functions should use the queued pipeline.",
        "",
        "## Queued occurrence processing",
        "",
        "The queued method is the current preferred method.",
        "",
        "The older method toggled each occurrence immediately during search.",
        "",
        "The faster method separates search from action.",
        "",
        "The faster method does this.",
        "",
        "1. Search all matching tagged occurrences.",
        "2. Store each match in `System.Collections.ArrayList`.",
        "3. Determine which matches already have the desired state.",
        "4. For iAssemblies, multi select only occurrences that need the toggle.",
        "5. Run `ExcludeCtxCmd` once.",
        "6. Verify every queued occurrence.",
        "7. Fall back to one by one only for failures.",
        "8. Update and save once at the end.",
        "",
        "This avoids repeated update and save calls inside the recursive search loop.",
        "",
        "This is especially important for iAssembly exclusions because UI command execution and model updates are expensive.",
        "",
        "## Required queued helper functions",
        "",
        "Generated code should include these occurrence helpers.",
        "",
        "```text",
        "SuppressOccurrencesByTag",
        "UnsuppressOccurrencesByTagSafe",
        "CollectOccurrencesByTag",
        "ApplyQueuedMatchedTaggedOccurrencesActive",
        "SetMatchedTaggedOccurrenceActive",
        "IsOccurrenceExcludedInActiveIAssemblyRow",
        "```",
        "",
        "## Normal assembly occurrence path",
        "",
        "Normal assemblies should use the normal API path.",
        "",
        "For suppress:",
        "",
        "```vb",
        "If Not occ.Suppressed Then",
        "    occ.Suppress()",
        "End If",
        "```",
        "",
        "For unsuppress:",
        "",
        "```vb",
        "If occ.Suppressed Then",
        "    occ.Unsuppress()",
        "End If",
        "```",
        "",
        "Normal assemblies do not need `ExcludeCtxCmd`.",
        "",
        "Normal assemblies do not need iAssembly row verification.",
        "",
        "## iAssembly occurrence path",
        "",
        "iAssembly factories do not behave like normal assemblies for occurrence suppression.",
        "",
        "Direct occurrence suppression can fail with invalid argument errors.",
        "",
        "Direct table cell assignment can fail with COM errors.",
        "",
        "The verified working path is to use Inventor's own context command.",
        "",
        "```vb",
        "app.CommandManager.ControlDefinitions.Item(""ExcludeCtxCmd"").Execute()",
        "```",
        "",
        "`ExcludeCtxCmd` behaves like the right click Exclude checkbox.",
        "",
        "If the occurrence is currently included, running the command excludes it.",
        "",
        "If the occurrence is currently excluded, running the command includes it.",
        "",
        "Because it is a toggle, the code must check current state before running it.",
        "",
        "## iAssembly desired state logic",
        "",
        "The generated code uses this logic.",
        "",
        "```vb",
        "Dim beforeExcluded As Boolean = IsOccurrenceExcludedInActiveIAssemblyRow(occ)",
        "Dim wantedExcluded As Boolean = Not activeState",
        "",
        "If beforeExcluded = wantedExcluded Then",
        "    Return True",
        "End If",
        "```",
        "",
        "`activeState = False` means the occurrence should be suppressed or excluded.",
        "",
        "`activeState = True` means the occurrence should be unsuppressed or included.",
        "",
        "Therefore:",
        "",
        "```vb",
        "Dim wantedExcluded As Boolean = Not activeState",
        "```",
        "",
        "When wanted state differs from current state, the code selects the occurrence and runs `ExcludeCtxCmd`.",
        "",
        "## iAssembly state verification",
        "",
        "The code verifies iAssembly state with the active iAssembly factory row.",
        "",
        "```vb",
        "Return CBool(CallByName(rowObj, ""IsExcluded"", CallType.Method, occ))",
        "```",
        "",
        "If the active document is not an iAssembly factory, the helper falls back to `occ.Suppressed`.",
        "",
        "This makes the same helper usable in both normal assembly and iAssembly contexts.",
        "",
        "## Why direct Excluded property is not used",
        "",
        "Do not use this:",
        "",
        "```vb",
        "occ.Excluded = False",
        "```",
        "",
        "In this Inventor iLogic context, `Excluded` was not available on the selected `ComponentOccurrence` object.",
        "",
        "The observed error was member not found.",
        "",
        "This means the selected occurrence cannot be controlled through a simple `occ.Excluded` property.",
        "",
        "## Why direct table cell editing is not used",
        "",
        "The iAssembly table can show a column like this:",
        "",
        "```text",
        "ASSIEME RUOTA:1:Include/Exclude",
        "```",
        "",
        "The cell value can show:",
        "",
        "```text",
        "Exclude",
        "```",
        "",
        "However, direct cell assignment can still fail.",
        "",
        "Example of the unreliable path:",
        "",
        "```vb",
        "CallByName(cellObj, ""Value"", CallType.Set, ""Include"")",
        "```",
        "",
        "Even when the column exists and the value is visible, Inventor may reject direct assignment with an unspecified COM error.",
        "",
        "Because right click Exclude works reliably, the correct automation path is to preselect the occurrence and run `ExcludeCtxCmd`.",
        "",
        "## Why Component.IsActive is not the main path",
        "",
        "Do not use this as the primary iAssembly method:",
        "",
        "```vb",
        "Component.IsActive(occ.Name) = False",
        "```",
        "",
        "`Component.IsActive` can be useful in simple iLogic cases, but it was not reliable for the iAssembly occurrence case handled by this tool.",
        "",
        "The tag system still finds by tag.",
        "",
        "The occurrence name is only a transient handle and should not become the targeting method.",
        "",
        "## Tag based targeting rule",
        "",
        "The action target is always the tag.",
        "",
        "The tool should never become name based.",
        "",
        "Correct logic:",
        "",
        "```text",
        "Find matching document tag",
        "Get the matching occurrence object",
        "Apply the state change to that occurrence object",
        "```",
        "",
        "Incorrect logic:",
        "",
        "```text",
        "Search by occurrence browser name",
        "Suppress by occurrence browser name",
        "```",
        "",
        "Occurrence names are only used indirectly by Inventor when a selected occurrence is passed to the command system.",
        "",
        "## Feature replay pipeline",
        "",
        "Feature actions are different from occurrence actions.",
        "",
        "Feature actions target part features by feature name on tagged part documents.",
        "",
        "The generated feature replay uses a temporary external iLogic rule.",
        "",
        "The temp rule name is:",
        "",
        "```text",
        "__TEMP_TAG_FEATURE_ACTIVE",
        "```",
        "",
        "The generated temp rule body is:",
        "",
        "```vb",
        "Sub Main()",
        "    Feature.IsActive(""FeatureName"") = True",
        "End Sub",
        "```",
        "",
        "or:",
        "",
        "```vb",
        "Sub Main()",
        "    Feature.IsActive(""FeatureName"") = False",
        "End Sub",
        "```",
        "",
        "The tool writes the temp rule into the first valid external rule directory.",
        "",
        "Then it runs that external rule against each tagged part.",
        "",
        "After processing, it attempts to delete the temporary rule file.",
        "",
        "## Required generated helper map",
        "",
        "A complete generated replay rule should include these helpers.",
        "",
        "### Tag helpers",
        "",
        "```text",
        "HasTagValue",
        "GetTagValue",
        "HasComponentDefinitionTagValue",
        "```",
        "",
        "### Document resolution helpers",
        "",
        "```text",
        "GetOccurrenceDocumentSafe",
        "```",
        "",
        "### Occurrence action helpers",
        "",
        "```text",
        "SuppressOccurrencesByTag",
        "UnsuppressOccurrencesByTagSafe",
        "CollectOccurrencesByTag",
        "ApplyQueuedMatchedTaggedOccurrencesActive",
        "SetMatchedTaggedOccurrenceActive",
        "IsOccurrenceExcludedInActiveIAssemblyRow",
        "```",
        "",
        "### Feature action helpers",
        "",
        "```text",
        "SetFeatureActiveByTag",
        "GetFirstExternalRuleDirectory",
        "```",
        "",
        "## Helpers that should not be generated anymore",
        "",
        "These helpers are old or unreliable and should not be emitted by `GetGeneratedHelperCode`.",
        "",
        "```text",
        "SetOccurrenceSuppressedOrExcluded",
        "SetIAssemblyOccurrenceIncludedByRowCell",
        "SetIAssemblyOccurrenceExcludedByRowCell",
        "SetIAssemblyOccurrenceExcludedStateByRowCell",
        "UnsuppressOccurrencesByTag",
        "```",
        "",
        "`SetOccurrenceSuppressedOrExcluded` used older suppression logic and does not handle iAssembly factories correctly.",
        "",
        "`SetIAssemblyOccurrenceIncludedByRowCell`, `SetIAssemblyOccurrenceExcludedByRowCell`, and `SetIAssemblyOccurrenceExcludedStateByRowCell` rely on direct table cell assignment, which is not reliable in this context.",
        "",
        "`UnsuppressOccurrencesByTag` is the older unsafe unsuppress helper and should be replaced by `UnsuppressOccurrencesByTagSafe`.",
        "",
        "## Document resolution strategy",
        "",
        "Suppressed or excluded occurrences may not expose their document through the simplest path.",
        "",
        "The helper should try multiple paths.",
        "",
        "First:",
        "",
        "```vb",
        "occ.Definition.Document",
        "```",
        "",
        "Then:",
        "",
        "```vb",
        "occ.ReferencedDocumentDescriptor.ReferencedDocument",
        "```",
        "",
        "Then:",
        "",
        "```vb",
        "occ.ReferencedDocumentDescriptor.FullDocumentName",
        "ThisApplication.Documents.Open(fullName, False)",
        "```",
        "",
        "Then:",
        "",
        "```vb",
        "occ.ReferencedFileDescriptor.FullFileName",
        "ThisApplication.Documents.Open(fileName, False)",
        "```",
        "",
        "This makes the tag search more resilient when components are suppressed, excluded, or not fully resolved.",
        "",
        "## Normal suppress replay example",
        "",
        "Generated suppress replay should require an assembly.",
        "",
        "```vb",
        "If asm Is Nothing Then",
        "    WF.MessageBox.Show(""Open an assembly first for occurrence suppression."")",
        "    Exit Sub",
        "End If",
        "",
        "SuppressOccurrencesByTag(asm.ComponentDefinition.Occurrences, TAG_NS, TAG_KEY, ""MyTag"")",
        "```",
        "",
        "## Normal unsuppress replay example",
        "",
        "Generated unsuppress replay should require an assembly.",
        "",
        "```vb",
        "If asm Is Nothing Then",
        "    WF.MessageBox.Show(""Open an assembly first for occurrence unsuppression."")",
        "    Exit Sub",
        "End If",
        "",
        "UnsuppressOccurrencesByTagSafe(asm.ComponentDefinition.Occurrences, TAG_NS, TAG_KEY, ""MyTag"")",
        "```",
        "",
        "## Normal feature suppress replay example",
        "",
        "If the active document is an assembly, feature replay searches all referenced parts.",
        "",
        "```vb",
        "SetFeatureActiveByTag(asm, TAG_NS, TAG_KEY, ""MyTag"", ""FeatureName"", False)",
        "```",
        "",
        "If the active document is a part, feature replay checks the active part tag and directly uses `Feature.IsActive`.",
        "",
        "```vb",
        "Feature.IsActive(""FeatureName"") = False",
        "```",
        "",
        "## Normal feature unsuppress replay example",
        "",
        "If the active document is an assembly, feature replay searches all referenced parts.",
        "",
        "```vb",
        "SetFeatureActiveByTag(asm, TAG_NS, TAG_KEY, ""MyTag"", ""FeatureName"", True)",
        "```",
        "",
        "If the active document is a part, feature replay checks the active part tag and directly uses `Feature.IsActive`.",
        "",
        "```vb",
        "Feature.IsActive(""FeatureName"") = True",
        "```",
        "",
        "## Recommended workflow for creating a suppress replay",
        "",
        "1. Open the top level assembly.",
        "2. Run the action recorder.",
        "3. Enter the intended custom tag.",
        "4. Click `SUPPRESS OCC`.",
        "5. Select one occurrence that represents the target group.",
        "6. Let the tool resolve or write the tag.",
        "7. Let the action run once.",
        "8. Review the generated replay code.",
        "9. Copy the generated replay code into a new iLogic rule.",
        "10. Test the generated rule.",
        "",
        "## Recommended workflow for creating an unsuppress replay",
        "",
        "1. Open the top level assembly.",
        "2. Run the action recorder.",
        "3. Click `UNSUPPRESS OCC`.",
        "4. Type the tag or choose `Select Occurrence`.",
        "5. Let the action run once.",
        "6. Review the generated replay code.",
        "7. Copy the generated replay code into a new iLogic rule.",
        "8. Test the generated rule.",
        "",
        "## Recommended workflow for feature actions",
        "",
        "1. Open the tagged part.",
        "2. Run the action recorder.",
        "3. Click `SUPPRESS FEATURE` or `UNSUPPRESS FEATURE`.",
        "4. Select the feature from the model tree.",
        "5. Confirm the generated replay code.",
        "6. Run the generated replay from a part or assembly context as needed.",
        "",
        "## Performance notes",
        "",
        "The fastest proven occurrence approach is queued processing.",
        "",
        "Do not update and save inside every recursive match.",
        "",
        "Do not run `ExcludeCtxCmd` one occurrence at a time unless the multi select path fails.",
        "",
        "Do not repeatedly open message boxes during batch processing.",
        "",
        "Do not add logging inside the replay path unless specifically debugging.",
        "",
        "Use one final update and save after the queued operation.",
        "",
        "## Known limitations",
        "",
        "1. The iAssembly command path depends on `ExcludeCtxCmd` being available in the current Inventor context.",
        "2. The command path depends on the occurrence being selectable.",
        "3. Direct table cell editing may fail even when the Include or Exclude column exists.",
        "4. Suppressed or excluded occurrences may not always resolve their referenced document.",
        "5. Feature actions depend on exact feature names.",
        "6. Feature actions require a valid external iLogic rule directory when replayed against referenced parts.",
        "7. The generated replay assumes the active document context is correct.",
        "",
        "## Troubleshooting duplicate function errors",
        "",
        "If the iLogic rule reports multiple definitions with identical signatures, search for the duplicated function and keep only one copy.",
        "",
        "Common duplicates:",
        "",
        "```text",
        "HasTagValue",
        "GetTagValue",
        "GetOccurrenceDocumentSafe",
        "HasComponentDefinitionTagValue",
        "SuppressOccurrencesByTag",
        "UnsuppressOccurrencesByTagSafe",
        "CollectOccurrencesByTag",
        "ApplyQueuedMatchedTaggedOccurrencesActive",
        "IsOccurrenceExcludedInActiveIAssemblyRow",
        "SetMatchedTaggedOccurrenceActive",
        "```",
        "",
        "Duplicate functions usually happen after pasting helper code more than once.",
        "",
        "## Troubleshooting iAssembly include or exclude",
        "",
        "If an iAssembly occurrence does not include or exclude, test the command directly.",
        "",
        "Expected behavior when currently excluded:",
        "",
        "```text",
        "Excluded before: True",
        "Excluded after: False",
        "```",
        "",
        "Expected behavior when currently included:",
        "",
        "```text",
        "Excluded before: False",
        "Excluded after: True",
        "```",
        "",
        "If this direct toggle works, generated replay should use the same `ExcludeCtxCmd` toggle path.",
        "",
        "If direct toggle fails, verify the occurrence is selectable and that the active document is the iAssembly factory.",
        "",
        "## Troubleshooting generated code missing queue logic",
        "",
        "If generated replay code still suppresses or unsuppresses one item at a time, replace `GetGeneratedHelperCode` with the version that emits these functions:",
        "",
        "```text",
        "CollectOccurrencesByTag",
        "ApplyQueuedMatchedTaggedOccurrencesActive",
        "```",
        "",
        "Then regenerate the replay code.",
        "",
        "## Troubleshooting missing external rule directory",
        "",
        "Feature replay against referenced parts requires an external iLogic rule directory.",
        "",
        "The helper reads:",
        "",
        "```vb",
        "iLogicVb.Automation.FileOptions.ExternalRuleDirectories",
        "```",
        "",
        "If no valid directory exists, feature replay cannot create the temporary rule.",
        "",
        "Set an external rule directory in Inventor iLogic configuration before using generated feature replay.",
        "",
        "## Maintenance rules",
        "",
        "1. Keep tag based targeting as the core behavior.",
        "2. Do not convert occurrence actions to name based targeting.",
        "3. Keep normal assembly and iAssembly logic separate.",
        "4. Keep `ExcludeCtxCmd` as the iAssembly toggle method.",
        "5. Keep queued occurrence processing in generated replay code.",
        "6. Keep the one by one fallback for failed queued toggles.",
        "7. Do not reintroduce direct iAssembly table cell assignment.",
        "8. Do not reintroduce `occ.Excluded`.",
        "9. Do not generate old unsafe unsuppress helpers.",
        "10. Keep generated code self contained.",
        "",
        "## Current best known occurrence logic",
        "",
        "The current best known occurrence logic is:",
        "",
        "```text",
        "Find tagged occurrence documents",
        "Queue the matching occurrences",
        "For normal assemblies, call Suppress or Unsuppress",
        "For iAssemblies, compare IsExcluded to wanted state",
        "Multi select occurrences that need toggling",
        "Run ExcludeCtxCmd once",
        "Verify",
        "Fallback one by one only where needed",
        "Update and save once",
        "```",
        "",
        "## Current best known iAssembly rule",
        "",
        "Use `ExcludeCtxCmd` as a toggle.",
        "",
        "Never run it blindly.",
        "",
        "Always check `IsExcluded` before running it.",
        "",
        "Always verify `IsExcluded` after running it.",
        "",
        "## Current best known generated replay rule",
        "",
        "Generated replay should be fully self contained.",
        "",
        "It should not depend on the original recorder rule.",
        "",
        "It should include all tag helpers, document helpers, occurrence helpers, queue helpers, iAssembly helpers, feature helpers, and external rule directory helpers.",
        "",
        "## End of internal reference"
    }

    Dim helpText As String = String.Join(vbCrLf, helpLines)

    Dim resultForm As New WF.Form()
    resultForm.Text = "Internal CAD Tag Code Help"
    resultForm.StartPosition = WF.FormStartPosition.CenterParent
    resultForm.Width = 1100
    resultForm.Height = 800

    Dim resultBox As New WF.TextBox()
    resultBox.Multiline = True
    resultBox.ReadOnly = False
    resultBox.ScrollBars = WF.ScrollBars.Both
    resultBox.WordWrap = False
    resultBox.Dock = WF.DockStyle.Fill
    resultBox.Font = New SD.Font("Consolas", 9.0!)
    resultBox.Text = helpText

    resultForm.Controls.Add(resultBox)
    resultForm.ShowDialog()

End Sub

Private Function ShowRemoveTagScopeForm() As String

    Dim f As New WF.Form()
    f.Text = "Remove Internal CAD Tag"
    f.FormBorderStyle = WF.FormBorderStyle.FixedDialog
    f.StartPosition = WF.FormStartPosition.CenterParent
    f.MinimizeBox = False
    f.MaximizeBox = False
    f.Width = 430
    f.Height = 155

    Dim lbl As New WF.Label()
    lbl.Left = 12
    lbl.Top = 14
    lbl.Width = 390
    lbl.Text = "Remove the internal CAD tag from a specific component or all components?"
    f.Controls.Add(lbl)

    Dim btnSpecific As New WF.Button()
    btnSpecific.Text = "Specific Component"
    btnSpecific.Width = 140
    btnSpecific.Height = 30
    btnSpecific.Left = 12
    btnSpecific.Top = 65
    btnSpecific.Tag = "SPECIFIC"
    AddHandler btnSpecific.Click, AddressOf ScopeButtonClick
    f.Controls.Add(btnSpecific)

    Dim btnAll As New WF.Button()
    btnAll.Text = "All Components"
    btnAll.Width = 120
    btnAll.Height = 30
    btnAll.Left = 162
    btnAll.Top = 65
    btnAll.Tag = "ALL"
    AddHandler btnAll.Click, AddressOf ScopeButtonClick
    f.Controls.Add(btnAll)

    Dim btnCancel As New WF.Button()
    btnCancel.Text = "Cancel"
    btnCancel.Width = 100
    btnCancel.Height = 30
    btnCancel.Left = 292
    btnCancel.Top = 65
    btnCancel.Tag = ""
    AddHandler btnCancel.Click, AddressOf ScopeButtonClick
    f.Controls.Add(btnCancel)

    f.ShowDialog()

    If f.Tag Is Nothing Then
        ShowRemoveTagScopeForm = ""
    Else
        ShowRemoveTagScopeForm = CStr(f.Tag)
    End If

End Function

Private Sub ScopeButtonClick(sender As Object, E As System.EventArgs)

    Dim btn As WF.Button = TryCast(sender, WF.Button)

    If btn Is Nothing Then Exit Sub

    Dim f As WF.Form = btn.FindForm()

    If f Is Nothing Then Exit Sub

    f.Tag = CStr(btn.Tag)
    f.Close()

End Sub

Private Function RemoveTagFromSpecificComponent(activeDoc As INV.Document, tagNs As String) As Integer

    If activeDoc Is Nothing Then Return 0

    If activeDoc.DocumentType = INV.DocumentTypeEnum.kPartDocumentObject OrElse activeDoc.DocumentType = INV.DocumentTypeEnum.kAssemblyDocumentObject Then

        Dim removed As Integer = RemoveTagFromDocument(activeDoc, tagNs)

        Try
            activeDoc.Save()
        Catch
        End Try

        Return removed

    End If

    Return 0

End Function

Private Function RemoveTagsFromAllComponents(topAsm As INV.AssemblyDocument, tagNs As String) As Integer

    Dim removedCount As Integer = 0

    removedCount += RemoveTagFromDocument(topAsm, tagNs)

    Dim d As INV.Document

    For Each d In topAsm.AllReferencedDocuments

        If d Is Nothing Then Continue For
        If String.IsNullOrEmpty(d.FullFileName) Then Continue For

        If d.DocumentType = INV.DocumentTypeEnum.kPartDocumentObject OrElse d.DocumentType = INV.DocumentTypeEnum.kAssemblyDocumentObject Then

            removedCount += RemoveTagFromDocument(d, tagNs)

            Try
                d.Save()
            Catch
            End Try

        End If

    Next

    Try
        topAsm.Save()
    Catch
    End Try

    Return removedCount

End Function

Private Function RemoveTagFromDocument(doc As INV.Document, tagNs As String) As Integer

    Dim removedCount As Integer = 0

    On Error Resume Next

    Dim docSets As INV.AttributeSets = doc.AttributeSets
    Dim docSet As INV.AttributeSet = docSets.Item(tagNs)

    If Err.Number = 0 AndAlso docSet IsNot Nothing Then
        docSet.Delete()
        removedCount += 1
    End If

    Err.Clear()

    If doc.DocumentType = INV.DocumentTypeEnum.kPartDocumentObject Then

        Dim p As INV.PartDocument = TryCast(doc, INV.PartDocument)

        If p IsNot Nothing Then

            Dim partSets As INV.AttributeSets = p.ComponentDefinition.AttributeSets
            Dim partSet As INV.AttributeSet = partSets.Item(tagNs)

            If Err.Number = 0 AndAlso partSet IsNot Nothing Then
                partSet.Delete()
                removedCount += 1
            End If

            Err.Clear()

        End If

    ElseIf doc.DocumentType = INV.DocumentTypeEnum.kAssemblyDocumentObject Then

        Dim asm As INV.AssemblyDocument = TryCast(doc, INV.AssemblyDocument)

        If asm IsNot Nothing Then

            Dim asmSets As INV.AttributeSets = asm.ComponentDefinition.AttributeSets
            Dim asmSet As INV.AttributeSet = asmSets.Item(tagNs)

            If Err.Number = 0 AndAlso asmSet IsNot Nothing Then
                asmSet.Delete()
                removedCount += 1
            End If

            Err.Clear()

        End If

    End If

    On Error GoTo 0

    Return removedCount

End Function

Private Function PickPartFeature(prompt As String) As Object

    Dim picked As Object = Nothing

    Try
        picked = ThisApplication.CommandManager.Pick(INV.SelectionFilterEnum.kPartFeatureFilter, prompt)
    Catch
        picked = Nothing
    End Try

    PickPartFeature = picked

End Function

Private Function GetFeatureName(featureObj As Object) As String

    On Error Resume Next

    Dim nm As String = CStr(CallByName(featureObj, "Name", CallType.Get))

    If Err.Number <> 0 Then
        Err.Clear()
        GetFeatureName = ""
    Else
        GetFeatureName = nm
    End If

    On Error GoTo 0

End Function

Private Function GetDetectedTagText(activeDoc As INV.Document, tagNs As String, tagKey As String) As String

    If activeDoc Is Nothing Then Return ""

    Dim docTag As String = GetTagValue(activeDoc, tagNs, tagKey)
    Dim defTag As String = ""

    If activeDoc.DocumentType = INV.DocumentTypeEnum.kPartDocumentObject Then

        Dim p As INV.PartDocument = TryCast(activeDoc, INV.PartDocument)

        If p IsNot Nothing Then
            defTag = GetTagValue(p.ComponentDefinition, tagNs, tagKey)
        End If

    ElseIf activeDoc.DocumentType = INV.DocumentTypeEnum.kAssemblyDocumentObject Then

        Dim asm As INV.AssemblyDocument = TryCast(activeDoc, INV.AssemblyDocument)

        If asm IsNot Nothing Then
            defTag = GetTagValue(asm.ComponentDefinition, tagNs, tagKey)
        End If

    End If

    If Not String.IsNullOrWhiteSpace(docTag) AndAlso Not String.IsNullOrWhiteSpace(defTag) Then

        If String.Compare(docTag, defTag, True) = 0 Then
            Return docTag
        Else
            Return "Document: " & docTag & " | Definition: " & defTag
        End If

    ElseIf Not String.IsNullOrWhiteSpace(docTag) Then

        Return "Document: " & docTag

    ElseIf Not String.IsNullOrWhiteSpace(defTag) Then

        Return "Definition: " & defTag

    End If

    Return "No internal CAD tag detected"

End Function

Private Function ResolveEffectiveTagForActiveFile(activeDoc As INV.Document, tagNs As String, tagKey As String, typedTag As String) As String

    If activeDoc Is Nothing Then Return typedTag

    Dim foundTags As New List(Of String)

    Dim docTag As String = GetTagValue(activeDoc, tagNs, tagKey)

    If Not String.IsNullOrWhiteSpace(docTag) Then
        If Not foundTags.Contains(docTag) Then foundTags.Add(docTag)
    End If

    If activeDoc.DocumentType = INV.DocumentTypeEnum.kPartDocumentObject Then

        Dim p As INV.PartDocument = TryCast(activeDoc, INV.PartDocument)

        If p IsNot Nothing Then
            Dim defTag As String = GetTagValue(p.ComponentDefinition, tagNs, tagKey)

            If Not String.IsNullOrWhiteSpace(defTag) Then
                If Not foundTags.Contains(defTag) Then foundTags.Add(defTag)
            End If
        End If

    ElseIf activeDoc.DocumentType = INV.DocumentTypeEnum.kAssemblyDocumentObject Then

        Dim asm As INV.AssemblyDocument = TryCast(activeDoc, INV.AssemblyDocument)

        If asm IsNot Nothing Then
            Dim defTag As String = GetTagValue(asm.ComponentDefinition, tagNs, tagKey)

            If Not String.IsNullOrWhiteSpace(defTag) Then
                If Not foundTags.Contains(defTag) Then foundTags.Add(defTag)
            End If
        End If

    End If

    If foundTags.Count = 0 Then
        Return typedTag
    End If

    If foundTags.Count = 1 Then
        Return foundTags(0)
    End If

    Return ShowTagChoiceForm(foundTags, typedTag)

End Function

Private Function ShowTagChoiceForm(foundTags As List(Of String), typedTag As String) As String

    Dim f As New WF.Form()
    f.Text = "Choose Internal CAD Tag"
    f.FormBorderStyle = WF.FormBorderStyle.FixedDialog
    f.StartPosition = WF.FormStartPosition.CenterParent
    f.MinimizeBox = False
    f.MaximizeBox = False
    f.Width = 460
    f.Height = 230

    Dim lbl As New WF.Label()
    lbl.Left = 12
    lbl.Top = 14
    lbl.Width = 420
    lbl.Text = "Multiple tags were detected. Choose which tag to use for this action."
    f.Controls.Add(lbl)

    Dim cbo As New WF.ComboBox()
    cbo.Left = 12
    cbo.Top = 48
    cbo.Width = 420
    cbo.DropDownStyle = WF.ComboBoxStyle.DropDownList

    Dim tagValue As String
    For Each tagValue In foundTags
        cbo.Items.Add(tagValue)
    Next

    If Not String.IsNullOrWhiteSpace(typedTag) Then
        cbo.Items.Add(typedTag)
    End If

    If cbo.Items.Count > 0 Then cbo.SelectedIndex = 0

    f.Controls.Add(cbo)

    Dim okBtn As New WF.Button()
    okBtn.Text = "OK"
    okBtn.Width = 90
    okBtn.Height = 28
    okBtn.Left = 242
    okBtn.Top = 125
    okBtn.DialogResult = WF.DialogResult.OK
    f.Controls.Add(okBtn)

    Dim cancelBtn As New WF.Button()
    cancelBtn.Text = "Cancel"
    cancelBtn.Width = 90
    cancelBtn.Height = 28
    cancelBtn.Left = 342
    cancelBtn.Top = 125
    cancelBtn.DialogResult = WF.DialogResult.Cancel
    f.Controls.Add(cancelBtn)

    f.AcceptButton = okBtn
    f.CancelButton = cancelBtn

    If f.ShowDialog() = WF.DialogResult.OK Then
        Return CStr(cbo.SelectedItem)
    End If

    Return ""

End Function
