    s &= "        If d.DocumentType <> INV.DocumentTypeEnum.kPartDocumentObject Then Continue For" & vbCrLf
    s &= vbCrLf
    s &= "        Dim p As INV.PartDocument = TryCast(d, INV.PartDocument)" & vbCrLf
